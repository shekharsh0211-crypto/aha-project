                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"Admin@1234\",\n  \"newPassword\": \"Admin@1234\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users/me/password", "host": ["{{baseUrl}}"], "path": ["users", "me", "password"] },
            "description": "Change the current user's password. Requires the existing password."
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "description": "Create, list, view, cancel, and rebook travel bookings",
      "item": [
        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "var json = pm.response.json();",
                  "if (json.success && json.data) {",
                  "    pm.collectionVariables.set('bookingId', json.data.id);",
                  "    console.log('Booking created:', json.data.referenceNumber);",
                  "}",
                  "pm.test('Has reference number', () => pm.expect(json.data.referenceNumber).to.include('BK-'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickupLocation\": \"123 Main St, San Francisco, CA\",\n  \"dropoffLocation\": \"SFO International Airport, Terminal 2\",\n  \"pickupDatetime\": \"2026-05-01T10:00:00\",\n  \"passengerCount\": 2,\n  \"specialInstructions\": \"Please bring child seat\",\n  \"totalAmount\": 85.50,\n  \"currency\": \"USD\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] },
            "description": "Create a new booking. bookingId is auto-saved to collection variables."
          }
        },
        {
          "name": "Create Booking - With Vehicle",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickupLocation\": \"456 Market St, San Francisco, CA\",\n  \"dropoffLocation\": \"Oakland International Airport\",\n  \"pickupDatetime\": \"2026-05-15T08:30:00\",\n  \"passengerCount\": 4,\n  \"vehicleId\": 1,\n  \"totalAmount\": 120.00,\n  \"currency\": \"USD\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
          }
        },
        {
          "name": "List Bookings",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has pagination', () => {",
                  "    var d = pm.response.json().data;",
                  "    pm.expect(d.totalElements).to.be.a('number');",
                  "    pm.expect(d.content).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/bookings?page=0&size=10&sortBy=createdAt&sortDir=desc",
              "host": ["{{baseUrl}}"],
              "path": ["bookings"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "sortBy", "value": "createdAt" },
                { "key": "sortDir", "value": "desc" },
                { "key": "status", "value": "PENDING", "disabled": true },
                { "key": "from", "value": "2026-01-01T00:00:00", "disabled": true },
                { "key": "to", "value": "2026-12-31T23:59:59", "disabled": true }
              ]
            },
            "description": "List bookings with optional filters: status, from, to date. Admin sees all; customer sees own."
          }
        },
        {
          "name": "List Bookings - Filter by Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/bookings?status=PENDING&page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["bookings"],
              "query": [
                { "key": "status", "value": "PENDING" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Booking Detail",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has status history', () => pm.expect(pm.response.json().data.statusHistory).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/bookings/{{bookingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["bookings", "{{bookingId}}"]
            },
            "description": "Get full booking detail including status history."
          }
        },
        {
          "name": "Cancel Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status is CANCELLED', () => pm.expect(pm.response.json().data.status).to.eql('CANCELLED'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/bookings/{{bookingId}}/cancel?reason=Change of plans",
              "host": ["{{baseUrl}}"],
              "path": ["bookings", "{{bookingId}}", "cancel"],
              "query": [{ "key": "reason", "value": "Change of plans" }]
            },
            "description": "Cancel a booking. Only PENDING, CONFIRMED, or IN_PROGRESS bookings can be cancelled."
          }
        },
        {
          "name": "Rebook Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "var json = pm.response.json();",
                  "if (json.success && json.data) {",
                  "    pm.collectionVariables.set('bookingId', json.data.id);",
                  "    console.log('Rebooking created:', json.data.referenceNumber);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickupLocation\": \"123 Main St, San Francisco, CA\",\n  \"dropoffLocation\": \"SFO International Airport, Terminal 2\",\n  \"pickupDatetime\": \"2026-06-10T09:00:00\",\n  \"passengerCount\": 2,\n  \"totalAmount\": 85.50,\n  \"currency\": \"USD\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/bookings/{{bookingId}}/rebook",
              "host": ["{{baseUrl}}"],
              "path": ["bookings", "{{bookingId}}", "rebook"]
            },
            "description": "Rebook a cancelled or completed booking. Original is marked REBOOKED; new booking is created."
          }
        }
      ]
    },
