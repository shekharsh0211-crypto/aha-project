    {
      "name": "Admin - User Management",
      "description": "Admin-only endpoints. Requires ROLE_ADMIN.",
      "item": [
        {
          "name": "Create Customer User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
